using System;
using System.Collections.Generic;
using System.Linq;
using cAlgo.API;
using cAlgo.API.Indicators;
using cAlgo.API.Internals;
using cAlgo.Indicators;

namespace cAlgo
{
    [Robot(TimeZone = TimeZones.UTC, AccessRights = AccessRights.None)]
    public class Fractingalper : Robot
    {
        [Parameter(DefaultValue = "Fractingalper")]
        public string Label { get; set; }

        [Parameter(DefaultValue = 5)]
        public int FractalPeriod { get; set; }

        [Parameter(DefaultValue = 0.3, Step = 0.1)]
        public double MinChangePips { get; set; }

        [Parameter(DefaultValue = 0.3, Step = 0.1)]
        public double StopOrderDistance { get; set; }

        [Parameter(DefaultValue = 1000)]
        public double Volume { get; set; }

        [Parameter(DefaultValue = 3, MinValue = 1, Step = 0.1)]
        public double TakeProfitPips { get; set; }

        private class Sequence
        {
            public List<Position> Positions { get; set; }
            public int Orders { get; set; }
        }

        private FullFractal _fractals;
        private Dictionary<TradeType, PendingOrder> _stopOrder = new Dictionary<TradeType, PendingOrder> { { TradeType.Buy, null }, { TradeType.Sell, null } };
        private Dictionary<TradeType, Sequence> _sequence = new Dictionary<TradeType, Sequence> { { TradeType.Buy, null }, { TradeType.Sell, null } };

        protected override void OnStart()
        {
            StopOrderDistance *= Symbol.PipSize;

            _fractals = Indicators.GetIndicator<FullFractal>(FractalPeriod, false, false, false, string.Empty, string.Empty, string.Empty);
            for (var index = 0; index < MarketSeries.Open.Count; index++)
            {
                _fractals.Calculate(index);
            }

            PendingOrders.Filled += OnPendingOrderFilled;
            Positions.Closed += OnPositionClosed;
        }

        private void OnPendingOrderFilled(PendingOrderFilledEventArgs obj)
        {
            var stopOrder = _stopOrder[obj.PendingOrder.TradeType];
            if (stopOrder != null && stopOrder == obj.PendingOrder)
            {
                _stopOrder[obj.PendingOrder.TradeType] = null;
                _sequence[obj.PendingOrder.TradeType] = new Sequence { Positions = new List<Position> { obj.Position }, Orders = 1 };
            }
        }

        private void OnPositionClosed(PositionClosedEventArgs obj)
        {
            var sequence = _sequence[obj.Position.TradeType];
            if (sequence != null && sequence.Positions.Contains(obj.Position))
            {
                sequence.Positions.Remove(obj.Position);
                sequence.Positions.ForEach(x => ClosePosition(x));

                _sequence[obj.Position.TradeType] = null;
            }
        }

        protected override void OnBar()
        {
            var index = MarketSeries.Open.Count - 2;
            _fractals.Calculate(index);

            var lastHighChangePips = Math.Round(_fractals.horizontalContinuationLineHigh.LastChange(index) / Symbol.PipSize, 1);
            var lastLowChangePips = Math.Round(_fractals.horizontalContinuationLineLow.LastChange(index) / Symbol.PipSize, 1);

            //if (lastHighChangePips >= MinChangePips && _sequence[TradeType.Buy] == null)
            //{
            //    var targetPrice = Math.Round(_fractals.horizontalContinuationLineHigh[index], Symbol.Digits) + StopOrderDistance;
            //    if (_stopOrder[TradeType.Buy] == null)
            //    {
            //        _stopOrder[TradeType.Buy] = PlaceStopOrder(TradeType.Buy, Symbol, Volume, targetPrice, Label, null, TakeProfitPips, null, "Initial").PendingOrder;
            //    }
            //    else if (_stopOrder[TradeType.Buy].TargetPrice != targetPrice)
            //    {
            //        _stopOrder[TradeType.Buy].ModifyTargetPrice(targetPrice);
            //    }
            //}

            if (lastLowChangePips <= -MinChangePips && _sequence[TradeType.Sell] == null)
            {
                var targetPrice = Math.Round(_fractals.horizontalContinuationLineLow[index], Symbol.Digits) - StopOrderDistance;
                if (_stopOrder[TradeType.Sell] == null)
                {
                    _stopOrder[TradeType.Sell] = PlaceStopOrder(TradeType.Sell, Symbol, Volume, targetPrice, Label, null, TakeProfitPips, null, "Initial").PendingOrder;
                }
                else if (_stopOrder[TradeType.Sell].TargetPrice != targetPrice)
                {
                    _stopOrder[TradeType.Sell].ModifyTargetPrice(targetPrice);
                }
            }
        }

        protected override void OnTick()
        {
            foreach (var sequence in _sequence.Values)
            {
                if (sequence == null)
                {
                    continue;
                }

                if (sequence.Positions.Count == 1)
                {
                    if (sequence.Positions[0].Pips <= -TakeProfitPips)
                    {
                        var volume = sequence.Positions[0].VolumeInUnits * 2 + Volume;
                        var tradeType = (TradeType)Math.Abs((int)sequence.Positions[0].TradeType - 1);

                        sequence.Positions.Add(ExecuteMarketOrder(tradeType, Symbol, volume, Label, null, null, null, "Hedge").Position);
                        sequence.Orders++;

                        AdjustTargets(sequence);
                    }
                }
                else
                {
                    var smallerPosition = sequence.Positions.OrderBy(x => x.VolumeInUnits).First();
                    var biggerPosition = sequence.Positions.OrderBy(x => x.VolumeInUnits).Last();

                    if (biggerPosition.Pips <= -TakeProfitPips)
                    {
                        var volume = smallerPosition.VolumeInUnits + biggerPosition.VolumeInUnits * 2 + Volume * sequence.Orders;
                        smallerPosition.ModifyVolume(volume);

                        sequence.Orders++;

                        AdjustTargets(sequence);
                    }
                }
            }
        }

        private void AdjustTargets(Sequence sequence)
        {
            var distancePips = Math.Round(Math.Abs(sequence.Positions[0].EntryPrice - sequence.Positions[1].EntryPrice) / Symbol.PipSize, 1);
            foreach (var position in sequence.Positions)
            {
                position.ModifyTakeProfitPips(distancePips);
            }
        }

        protected override void OnStop()
        {
            // Put your deinitialization logic here
        }
    }

    public static class Functions
    {
        public static double LastChange(this IndicatorDataSeries series, int index)
        {
            var change = 0.0;
            for (var i = index - 1; i >= 0; i--)
            {
                if (series[i] != series[index])
                {
                    change = series[index] - series[i];
                    break;
                }
            }

            return change;
        }
    }
}